{
  "name": "finance-buddy",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev:mobile": "cd mobile && npx expo start",
    "install:all": "cd server && npm install && cd ../client && npm install && cd ../mobile && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
